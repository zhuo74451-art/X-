# ============================================================
# X Automation v0.1.0 - 环境变量模板
# ============================================================
# 复制此文件为 .env 后填入真实值
# cp .env.example .env
#
# ⚠️ .env 已被 .gitignore 忽略，不会被提交到 Git
# ⚠️ 所有开关默认关闭，确保安全
# ============================================================

# --- X/Twitter API 凭证（仅真实发帖时需要） ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- 模型 API Key ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- 模型配置 ---
MODEL_RUNTIME=mock
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
MODEL_TIMEOUT_SECONDS=90

# --- 安全开关（默认全部关闭） ---
# 真实 X 发帖开关
ENABLE_X_POST=false

# 自动发布开关
ENABLE_AUTO_PUBLISH=false

# 付费模型调用开关
ENABLE_MODEL_CALL=false

# 后台进程开关
ENABLE_DAEMON=false

# 全局 Dry-Run 开关
DRY_RUN=true

# --- 发布配置 ---
AUTO_PUBLISH_ENABLED=false
AUTO_PUBLISH_DRY_RUN=true

# --- 数据库 ---
DB_PATH=hot_follow.db

# --- 日志 ---
LOG_PATH=logs/run.log
